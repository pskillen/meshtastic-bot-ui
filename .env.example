# Meshtastic Bot UI – Environment Variables
# Copy to .env and fill in values. Vite exposes only variables prefixed with VITE_.

# Mapbox access token for the Traceroute Heatmap page.
# Required for /traceroutes/heatmap. Get a token at https://account.mapbox.com/
# Scopes: styles:read, fonts:read, tiles:read
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# API configuration is primarily loaded from public/config.json (or defaults in config.ts).
# These env vars are declared for optional override; check config.ts if you need to use them.
# VITE_API_BASE_URL=http://localhost:8000
# VITE_API_TOKEN=
# VITE_API_USERNAME=
# VITE_API_PASSWORD=
# VITE_API_KEY=
